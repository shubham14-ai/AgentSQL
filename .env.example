# Copy to .env and fill in your values

APP_NAME=AgentSQL
ENVIRONMENT=development
LOG_LEVEL=INFO

# LLM — NVIDIA NIM (OpenAI-compatible endpoint)
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=deepseek-ai/deepseek-r1

# Application database (stores project metadata — any SQLAlchemy-supported URL)
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/agentsql
# Docker users: replace localhost → host.docker.internal

# Infrastructure
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333

CORS_ORIGINS=http://localhost:3000
